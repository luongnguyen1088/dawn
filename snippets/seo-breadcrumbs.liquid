{% comment %}
  Renders breadcrumbs JSON-LD schema for SEO.
{% endcomment %}
{%- unless template == 'index' or template == 'cart' or template == 'list-collections' or template == '404' -%}
  {%- assign home_url = shop.url -%}
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      {
        "@type": "ListItem",
        "position": 1,
        "name": "Home",
        "item": {{ home_url | json }}
      }
      {%- if template.name == 'product' -%}
        {%- if collection -%}
          ,{
            "@type": "ListItem",
            "position": 2,
            "name": {{ collection.title | json }},
            "item": {{ home_url | append: collection.url | json }}
          },
          {
            "@type": "ListItem",
            "position": 3,
            "name": {{ product.title | json }},
            "item": {{ home_url | append: product.url | json }}
          }
        {%- else -%}
          ,{
            "@type": "ListItem",
            "position": 2,
            "name": {{ product.title | json }},
            "item": {{ home_url | append: product.url | json }}
          }
        {%- endif -%}
      {%- elsif template.name == 'collection' and collection.handle -%}
        ,{
          "@type": "ListItem",
          "position": 2,
          "name": {{ collection.title | json }},
          "item": {{ home_url | append: collection.url | json }}
        }
      {%- elsif template.name == 'blog' -%}
        ,{
          "@type": "ListItem",
          "position": 2,
          "name": {{ blog.title | json }},
          "item": {{ home_url | append: blog.url | json }}
        }
      {%- elsif template.name == 'article' -%}
        ,{
          "@type": "ListItem",
          "position": 2,
          "name": {{ blog.title | json }},
          "item": {{ home_url | append: blog.url | json }}
        },
        {
          "@type": "ListItem",
          "position": 3,
          "name": {{ article.title | json }},
          "item": {{ home_url | append: article.url | json }}
        }
      {%- elsif template.name == 'page' -%}
        ,{
          "@type": "ListItem",
          "position": 2,
          "name": {{ page.title | json }},
          "item": {{ home_url | append: page.url | json }}
        }
      {%- endif -%}
    ]
  }
  </script>
{%- endunless -%}
