{% comment %}
  Renders product variant options

  Accepts:
  - product: {Object} product object.
  - option: {Object} current product_option object.
  - block: {Object} block object.
  - picker_type: {String} type of picker to dispay


  Usage:
  {% render 'product-variant-options',
    product: product,
    option: option,
    block: block
    picker_type: picker_type
  %}
{% endcomment %}
{%- liquid
  assign product_form_id = 'product-form-' | append: section.id
-%}

{%- for value in option.values -%}
  {%- liquid
    assign swatch_focal_point = null
    if value.swatch.image
      assign image_url = value.swatch.image | image_url: width: 50
      assign swatch_value = 'url(' | append: image_url | append: ')'
      assign swatch_focal_point = value.swatch.image.presentation.focal_point
    elsif value.swatch.color
      assign swatch_value = 'rgb(' | append: value.swatch.color.rgb | append: ')'
    else
      assign swatch_value = null

      # Fallback to custom color mappings
      if swatch_value == null
        assign color_name_downcase = value | downcase | split: '(' | first | strip
        assign custom_color = null
        if color_name_downcase contains 'hồng dâu' or color_name_downcase contains 'strawberry' or color_name_downcase contains 'light pink'
          assign custom_color = '#ffccd5'
        elsif color_name_downcase contains 'hồng sen' or color_name_downcase contains 'hong sen' or color_name_downcase contains 'pink' or color_name_downcase contains 'hồng' or color_name_downcase contains 'hong'
          assign custom_color = '#ffb3c1'
        elsif color_name_downcase contains 'kem' or color_name_downcase contains 'cream' or color_name_downcase contains 'beige' or color_name_downcase contains 'sand' or color_name_downcase contains 'khaki'
          assign custom_color = '#fdf6e2'
        elsif color_name_downcase contains 'trắng' or color_name_downcase contains 'trang' or color_name_downcase contains 'white'
          assign custom_color = '#ffffff'
        elsif color_name_downcase contains 'đen' or color_name_downcase contains 'den' or color_name_downcase contains 'black'
          assign custom_color = '#111111'
        elsif color_name_downcase contains 'xanh than' or color_name_downcase contains 'navy'
          assign custom_color = '#1b2a47'
        elsif color_name_downcase contains 'xanh trời' or color_name_downcase contains 'xanh troi' or color_name_downcase contains 'light blue' or color_name_downcase contains 'sky blue'
          assign custom_color = '#8ecae6'
        elsif color_name_downcase contains 'xanh dương' or color_name_downcase contains 'blue' or color_name_downcase contains 'royal'
          assign custom_color = '#2980b9'
        elsif color_name_downcase contains 'xanh lá' or color_name_downcase contains 'green' or color_name_downcase contains 'olive'
          assign custom_color = '#1e4620'
        elsif color_name_downcase contains 'nâu' or color_name_downcase contains 'brown' or color_name_downcase contains 'chocolate' or color_name_downcase contains 'cacao'
          assign custom_color = '#7d5c41'
        elsif color_name_downcase contains 'đỏ' or color_name_downcase contains 'red' or color_name_downcase contains 'maroon' or color_name_downcase contains 'burgundy' or color_name_downcase contains 'cardinal'
          assign custom_color = '#c0392b'
        elsif color_name_downcase contains 'vàng' or color_name_downcase contains 'yellow' or color_name_downcase contains 'gold'
          assign custom_color = '#f1c40f'
        elsif color_name_downcase contains 'cam' or color_name_downcase contains 'orange'
          assign custom_color = '#e67e22'
        elsif color_name_downcase contains 'tím' or color_name_downcase contains 'purple'
          assign custom_color = '#8e44ad'
        elsif color_name_downcase contains 'xám chì' or color_name_downcase contains 'charcoal' or color_name_downcase contains 'dark gray'
          assign custom_color = '#546e7a'
        elsif color_name_downcase contains 'xám' or color_name_downcase contains 'gray' or color_name_downcase contains 'grey'
          assign custom_color = '#b0bec5'
        endif

        if custom_color != blank
          assign swatch_value = custom_color
        else
          assign swatch_value = color_name_downcase
        endif
      endif
    endif

    assign option_disabled = true
    if value.available
      assign option_disabled = false
    endif
  -%}

  {%- capture input_id -%}
    {{ section.id }}-{{ option.position }}-{{ forloop.index0 -}}
  {%- endcapture -%}

  {%- capture input_name -%}
    {{ option.name }}-{{ option.position }}
  {%- endcapture -%}

  {%- capture input_dataset -%}
    data-product-url="{{ value.product_url }}"
    data-option-value-id="{{ value.id }}"
    data-option-name="{{ option.name | escape }}"
  {%- endcapture -%}

  {%- capture label_unavailable -%}
    <span class="visually-hidden label-unavailable">
      {{- 'products.product.variant_sold_out_or_unavailable' | t -}}
    </span>
  {%- endcapture -%}

  {% assign escaped_value = value | escape %}

  {%- if picker_type == 'swatch' -%}
    {%- capture help_text -%}
      <span class="visually-hidden">{{ escaped_value }}</span>
      {{ label_unavailable }}
    {%- endcapture -%}

    {%
      render 'swatch-input',
      id: input_id,
      name: input_name,
      value: escaped_value,
      swatch: value.swatch,
      custom_swatch_value: swatch_value,
      product_form_id: product_form_id,
      checked: value.selected,
      visually_disabled: option_disabled,
      shape: block.settings.swatch_shape,
      help_text: help_text,
      additional_props: input_dataset
    %}
  {%- elsif picker_type == 'button' -%}
    <input
      type="radio"
      id="{{ input_id }}"
      name="{{ input_name | escape }}"
      value="{{ escaped_value }}"
      form="{{ product_form_id }}"
      {% if value.selected %}
        checked
      {% endif %}
      {% if option_disabled %}
        class="disabled"
      {% endif %}
      {{ input_dataset }}
    >
    <label for="{{ input_id }}">
      {{ value | split: '(' | first | strip -}}
      {{ label_unavailable }}
    </label>
  {%- elsif picker_type == 'dropdown' or picker_type == 'swatch_dropdown' -%}
    <option
      id="{{ input_id }}"
      value="{{ escaped_value }}"
      {% if value.selected %}
        selected="selected"
      {% endif %}
      {% if swatch_value and picker_type == 'swatch_dropdown' %}
        data-option-swatch-value="{{ swatch_value }}"
        {% if swatch_focal_point %}
          data-option-swatch-focal-point="{{ swatch_focal_point }}"
        {% endif %}
      {% endif %}
      {{ input_dataset }}
    >
      {% if option_disabled -%}
        {%- assign clean_value = value | split: '(' | first | strip -%}
        {{- 'products.product.value_unavailable' | t: option_value: clean_value -}}
      {%- else -%}
        {{- value | split: '(' | first | strip -}}
      {%- endif %}
    </option>
  {%- endif -%}
{%- endfor -%}
