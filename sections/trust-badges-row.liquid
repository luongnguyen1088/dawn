{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  .trust-badges-row {
    border-top: 1px solid rgba(var(--color-foreground), 0.08);
    border-bottom: 1px solid rgba(var(--color-foreground), 0.08);
  }

  .trust-badges-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 2rem;
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  @media screen and (min-width: 990px) {
    .trust-badges-grid {
      grid-template-columns: repeat(4, 1fr);
      gap: 3rem;
    }
  }

  .trust-badge-card {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    padding: 1rem;
  }

  .trust-badge-card__icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 48px;
    height: 48px;
    margin-bottom: 1.2rem;
    color: rgb(var(--color-foreground));
    background: rgba(var(--color-foreground), 0.04);
    border-radius: 50%;
    padding: 1rem;
    transition: transform 0.3s ease, color 0.3s ease;
  }

  .trust-badge-card:hover .trust-badge-card__icon {
    transform: translateY(-4px);
    color: var(--gradient-base-accent-1);
    background: rgba(var(--color-foreground), 0.08);
  }

  .trust-badge-card__icon svg {
    width: 100%;
    height: 100%;
  }

  .trust-badge-card__title {
    font-size: 1.5rem;
    font-weight: 600;
    margin: 0 0 0.5rem 0;
    color: rgb(var(--color-foreground));
  }

  .trust-badge-card__desc {
    font-size: 1.3rem;
    margin: 0;
    color: rgba(var(--color-foreground), 0.75);
    line-height: 1.4;
  }
{%- endstyle -%}

<div class="trust-badges-row color-{{ section.settings.color_scheme }} gradient section-{{ section.id }}-padding">
  <div class="trust-badges-grid">
    {%- for block in section.blocks -%}
      <div class="trust-badge-card" {{ block.shopify_attributes }}>
        <div class="trust-badge-card__icon">
          {%- case block.settings.icon -%}
            {%- when 'shipping' -%}
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <rect x="1" y="3" width="15" height="13"></rect>
                <polygon points="16 8 20 8 23 11 23 16 16 16 16 8"></polygon>
                <circle cx="5.5" cy="18.5" r="2.5"></circle>
                <circle cx="18.5" cy="18.5" r="2.5"></circle>
              </svg>
            {%- when 'security' -%}
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <rect x="3" y="11" width="18" height="11" rx="2" ry="2"></rect>
                <path d="M7 11V7a5 5 0 0 1 10 0v4"></path>
              </svg>
            {%- when 'guarantee' -%}
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="12" cy="8" r="7"></circle>
                <polyline points="8.21 13.89 7 23 12 20 17 23 15.79 13.88"></polyline>
              </svg>
            {%- when 'return' -%}
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <polyline points="23 4 23 10 17 10"></polyline>
                <path d="M20.49 15a9 9 0 1 1-2.12-9.36L23 10"></path>
              </svg>
          {%- endcase -%}
        </div>
        {%- if block.settings.title != blank -%}
          <h3 class="trust-badge-card__title">{{ block.settings.title | escape }}</h3>
        {%- endif -%}
        {%- if block.settings.description != blank -%}
          <p class="trust-badge-card__desc">{{ block.settings.description | escape }}</p>
        {%- endif -%}
      </div>
    {%- endfor -%}
  </div>
</div>

{% schema %}
{
  "name": "Trust Badges Row",
  "tag": "section",
  "class": "section",
  "max_blocks": 4,
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Top padding",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Bottom padding",
      "default": 36
    }
  ],
  "blocks": [
    {
      "type": "badge",
      "name": "Badge Item",
      "settings": [
        {
          "type": "select",
          "id": "icon",
          "label": "Icon",
          "options": [
            { "value": "shipping", "label": "Shipping Truck" },
            { "value": "security", "label": "Lock (Security)" },
            { "value": "guarantee", "label": "Award Medal (Guarantee)" },
            { "value": "return", "label": "Return Arrow" }
          ],
          "default": "shipping"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Fast US Shipping"
        },
        {
          "type": "text",
          "id": "description",
          "label": "Description",
          "default": "Standard delivery in 3-5 business days"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Trust Badges Row",
      "blocks": [
        { "type": "badge", "settings": { "icon": "shipping", "title": "Fast US Shipping", "description": "Standard delivery in 3-5 business days" } },
        { "type": "badge", "settings": { "icon": "guarantee", "title": "Satisfaction Guaranteed", "description": "Love your gift or your money back" } },
        { "type": "badge", "settings": { "icon": "security", "title": "100% Secure Checkout", "description": "SSL encrypted secure transactions" } },
        { "type": "badge", "settings": { "icon": "return", "title": "Easy Returns", "description": "Hassle-free returns within 30 days" } }
      ]
    }
  ]
}
{% endschema %}
