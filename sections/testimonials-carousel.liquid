{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  .testimonials-section {
    background-color: rgba(var(--color-foreground), 0.02);
    border-top: 1px solid rgba(var(--color-foreground), 0.05);
    border-bottom: 1px solid rgba(var(--color-foreground), 0.05);
  }

  .testimonials-title-wrapper {
    text-align: center;
    margin-bottom: 3.5rem;
    padding: 0 1.5rem;
  }

  .testimonials-title {
    margin: 0 0 1rem 0;
  }

  .testimonials-subtitle {
    font-size: 1.5rem;
    color: rgba(var(--color-foreground), 0.7);
    margin: 0;
  }

  .testimonials-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2.5rem;
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  @media screen and (min-width: 750px) {
    .testimonials-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media screen and (min-width: 990px) {
    .testimonials-grid {
      grid-template-columns: repeat(3, 1fr);
      gap: 3rem;
    }
  }

  .testimonial-card {
    background: rgb(var(--color-background));
    border: 1px solid rgba(var(--color-foreground), 0.08);
    border-radius: 12px;
    padding: 2.5rem;
    box-shadow: 0 4px 12px rgba(var(--color-foreground), 0.03);
    display: flex;
    flex-direction: column;
    height: 100%;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }

  .testimonial-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 10px 20px rgba(var(--color-foreground), 0.06);
    border-color: rgba(var(--color-foreground), 0.15);
  }

  .testimonial-stars {
    display: flex;
    gap: 0.2rem;
    margin-bottom: 1.5rem;
    color: #ffb800;
  }

  .testimonial-stars svg {
    width: 18px;
    height: 18px;
    fill: currentColor;
  }

  .testimonial-text {
    font-size: 1.4rem;
    line-height: 1.6;
    color: rgba(var(--color-foreground), 0.85);
    margin: 0 0 2rem 0;
    flex-grow: 1;
    font-style: italic;
  }

  .testimonial-author-info {
    display: flex;
    align-items: center;
    gap: 1.2rem;
    border-top: 1px solid rgba(var(--color-foreground), 0.06);
    padding-top: 1.5rem;
  }

  .testimonial-avatar {
    width: 44px;
    height: 44px;
    border-radius: 50%;
    object-fit: cover;
    border: 2px solid var(--gradient-base-accent-1);
    background-color: rgba(var(--color-foreground), 0.05);
  }

  .testimonial-author-details {
    display: flex;
    flex-direction: column;
  }

  .testimonial-author-name {
    font-size: 1.4rem;
    font-weight: 600;
    color: rgb(var(--color-foreground));
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .verified-badge {
    display: inline-flex;
    color: #00b0ff;
  }

  .verified-badge svg {
    width: 14px;
    height: 14px;
    fill: currentColor;
  }

  .testimonial-author-location {
    font-size: 1.2rem;
    color: rgba(var(--color-foreground), 0.5);
    margin-top: 0.2rem;
  }
{%- endstyle -%}

<div class="testimonials-section color-{{ section.settings.color_scheme }} gradient section-{{ section.id }}-padding">
  <div class="testimonials-title-wrapper">
    {%- if section.settings.title != blank -%}
      <h2 class="testimonials-title inline-richtext {{ section.settings.heading_size }}">{{ section.settings.title }}</h2>
    {%- endif -%}
    {%- if section.settings.subtitle != blank -%}
      <p class="testimonials-subtitle">{{ section.settings.subtitle | escape }}</p>
    {%- endif -%}
  </div>

  <div class="testimonials-grid">
    {%- for block in section.blocks -%}
      <div class="testimonial-card" {{ block.shopify_attributes }}>
        <div class="testimonial-stars">
          {%- assign rating = block.settings.rating | plus: 0 -%}
          {%- for i in (1..5) -%}
            {%- if i <= rating -%}
              <svg viewBox="0 0 24 24">
                <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"></polygon>
              </svg>
            {%- else -%}
              <svg viewBox="0 0 24 24" style="color: rgba(var(--color-foreground), 0.15);">
                <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"></polygon>
              </svg>
            {%- endif -%}
          {%- endfor -%}
        </div>

        {%- if block.settings.text != blank -%}
          <p class="testimonial-text">"{{ block.settings.text | escape }}"</p>
        {%- endif -%}

        <div class="testimonial-author-info">
          {%- if block.settings.image != blank -%}
            <img class="testimonial-avatar" src="{{ block.settings.image | image_url: width: 88, height: 88 }}" alt="{{ block.settings.author | escape }}" width="44" height="44" loading="lazy">
          {%- else -%}
            <div class="testimonial-avatar" style="display: flex; align-items: center; justify-content: center; font-weight: bold; color: rgb(var(--color-background)); background: var(--gradient-base-accent-1); font-size: 1.4rem;">
              {{ block.settings.author | slice: 0 | upcase }}
            </div>
          {%- endif -%}

          <div class="testimonial-author-details">
            <span class="testimonial-author-name">
              {{ block.settings.author | escape }}
              {%- if block.settings.verified -%}
                <span class="verified-badge" title="Verified Buyer">
                  <svg viewBox="0 0 24 24">
                    <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z"></path>
                  </svg>
                </span>
              {%- endif -%}
            </span>
            {%- if block.settings.location != blank -%}
              <span class="testimonial-author-location">{{ block.settings.location | escape }}</span>
            {%- endif -%}
          </div>
        </div>
      </div>
    {%- endfor -%}
  </div>
</div>

{% schema %}
{
  "name": "Testimonials Grid",
  "tag": "section",
  "class": "section",
  "max_blocks": 6,
  "settings": [
    {
      "type": "inline_richtext",
      "id": "title",
      "default": "What Our Customers Say",
      "label": "Heading"
    },
    {
      "type": "text",
      "id": "subtitle",
      "default": "Rated 4.9/5 stars by over 10,000+ happy customers in the US.",
      "label": "Subtitle"
    },
    {
      "type": "select",
      "id": "heading_size",
      "options": [
        { "value": "h2", "label": "t:sections.all.heading_size.options__1.label" },
        { "value": "h1", "label": "t:sections.all.heading_size.options__2.label" },
        { "value": "h0", "label": "t:sections.all.heading_size.options__3.label" }
      ],
      "default": "h1",
      "label": "t:sections.all.heading_size.label"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Top padding",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Bottom padding",
      "default": 36
    }
  ],
  "blocks": [
    {
      "type": "testimonial",
      "name": "Testimonial Card",
      "settings": [
        {
          "type": "select",
          "id": "rating",
          "label": "Rating",
          "options": [
            { "value": "5", "label": "5 Stars" },
            { "value": "4", "label": "4 Stars" },
            { "value": "3", "label": "3 Stars" }
          ],
          "default": "5"
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "Testimonial Content",
          "default": "I bought this personalized shirt as a gift for my husband's birthday. The print quality is top-notch and the shirt is extremely soft. He wears it all the time. Excellent customer service!"
        },
        {
          "type": "text",
          "id": "author",
          "label": "Author Name",
          "default": "Sarah M."
        },
        {
          "type": "text",
          "id": "location",
          "label": "Author Location",
          "default": "Dallas, TX"
        },
        {
          "type": "checkbox",
          "id": "verified",
          "label": "Is Verified Buyer",
          "default": true
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Author Avatar (Optional)"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Testimonials Grid",
      "blocks": [
        {
          "type": "testimonial",
          "settings": {
            "author": "Sarah M.",
            "location": "Dallas, TX",
            "text": "I bought this personalized shirt as a gift for my husband's birthday. The print quality is top-notch and the fabric is extremely soft. Excellent customer service!",
            "rating": "5"
          }
        },
        {
          "type": "testimonial",
          "settings": {
            "author": "David K.",
            "location": "Chicago, IL",
            "text": "The custom upload was super easy to use. The photo preview let me see exactly how it would look, and the final print came out perfectly sharp. Shipping was fast!",
            "rating": "5"
          }
        },
        {
          "type": "testimonial",
          "settings": {
            "author": "Emily R.",
            "location": "Orlando, FL",
            "text": "Best gift ever! My mom literally cried tears of joy when she saw the custom shirt. Ordering was quick and the packaging was lovely. Highly recommend Snapzy!",
            "rating": "5"
          }
        }
      ]
    }
  ]
}
{% endschema %}
