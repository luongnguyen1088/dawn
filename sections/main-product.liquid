                            </div>
                            <div class="fbt-item-image">
                              <img src="{{ fbt_p2.featured_image | image_url: width: 150 }}" alt="{{ fbt_p2.title | escape }}" loading="lazy" width="75" height="75">
                            </div>
                            <div class="fbt-item-details">
                              <a href="{{ fbt_p2.url }}" class="fbt-item-title link">{{ fbt_p2.title }}</a>
                              <span class="fbt-item-price price">{{ fbt_p2.selected_or_first_available_variant.price | money }}</span>
                              
                              {%- if fbt_p2.variants.size > 1 -%}
                                <select class="fbt-variant-select select__select" id="fbt-variant-2" style="padding: 0.5rem; margin-top: 0.5rem; font-size: 1.2rem; min-height: auto;">
                                  {%- for variant in fbt_p2.variants -%}
                                    <option value="{{ variant.id }}" data-price="{{ variant.price }}" {% unless variant.available %}disabled{% endunless %}>
                                      {{ variant.title }} - {{ variant.price | money }}
                                    </option>
                                  {%- endfor -%}
                                </select>
                              {%- else -%}
                                <input type="hidden" id="fbt-variant-2" value="{{ fbt_p2.selected_or_first_available_variant.id }}">
                              {%- endif -%}
                            </div>
                          </div>
                        {%- endif -%}
                      </div>

                      <div class="fbt-action-area" style="margin-top: 1.5rem; display: flex; flex-direction: column; gap: 1rem;">
                        <div class="fbt-total-price-wrapper" style="font-size: 1.6rem; font-weight: bold;">
                          Total Price: <span class="fbt-total-price">{{ product.selected_or_first_available_variant.price | money }}</span>
                        </div>
                        <button type="button" class="fbt-submit-btn button button--primary" style="width: 100%;">
                          {{ block.settings.button_text | default: "Add Combo to Cart" }}
                        </button>
                      </div>
                    </div>
                    
                    <script>
                      (function() {
                        const container = document.querySelector('.product__fbt');
                        if (!container) return;

                        const totalEl = container.querySelector('.fbt-total-price');
                        const submitBtn = container.querySelector('.fbt-submit-btn');

                        function formatMoney(cents) {
                          return '$' + (cents / 100).toFixed(2);
                        }

                        function calculateTotal() {
                          let totalCents = 0;

                          const mainItem = container.querySelector('.main-product-fbt');
                          if (mainItem) {
                            totalCents += parseInt(mainItem.getAttribute('data-price')) || 0;
                          }

                          const cb1 = container.querySelector('#fbt-checkbox-1');
                          if (cb1 && cb1.checked) {
                            const variantSelect1 = container.querySelector('#fbt-variant-1');
                            if (variantSelect1) {
                              if (variantSelect1.tagName === 'SELECT') {
                                const opt = variantSelect1.options[variantSelect1.selectedIndex];
                                totalCents += parseInt(opt.getAttribute('data-price')) || 0;
                              } else {
                                totalCents += parseInt(container.querySelector('.fbt-items-container .fbt-item:nth-of-type(3)').getAttribute('data-price')) || 0;
                              }
                            }
                          }

                          const cb2 = container.querySelector('#fbt-checkbox-2');
                          if (cb2 && cb2.checked) {
                            const variantSelect2 = container.querySelector('#fbt-variant-2');
                            if (variantSelect2) {
                              if (variantSelect2.tagName === 'SELECT') {
                                const opt = variantSelect2.options[variantSelect2.selectedIndex];
                                totalCents += parseInt(opt.getAttribute('data-price')) || 0;
                              } else {
                                totalCents += parseInt(container.querySelector('.fbt-items-container .fbt-item:nth-of-type(5)').getAttribute('data-price')) || 0;
                              }
                            }
                          }

                          if (totalEl) {
                            totalEl.textContent = formatMoney(totalCents);
                          }
                        }

                        const mainVariantPrices = {
                          {%- for variant in product.variants -%}
                            "{{ variant.id }}": {{ variant.price }}{% unless forloop.last %},{% endunless %}
                          {%- endfor -%}
                        };

                        if (window.subscribe && window.PUB_SUB_EVENTS) {
                          subscribe(PUB_SUB_EVENTS.variantChange, (event) => {
                            const variant = event.data.variant;
                            if (variant) {
                              const price = variant.price;
                              const val = variant.id;
                              const mainItem = container.querySelector('.main-product-fbt');
                              if (mainItem) {
                                mainItem.setAttribute('data-price', price);
                                const mainPriceEl = mainItem.querySelector('.fbt-item-price');
                                if (mainPriceEl) mainPriceEl.textContent = formatMoney(price);
                                const mainVarInput = mainItem.querySelector('#fbt-variant-main');
                                if (mainVarInput) mainVarInput.value = val;
                                calculateTotal();
                              }
                            }
                          });
                        }

                        container.querySelectorAll('input[type="checkbox"], select').forEach(element => {
                          element.addEventListener('change', () => {
                            if (element.tagName === 'SELECT') {
                              const opt = element.options[element.selectedIndex];
                              const price = opt.getAttribute('data-price');
                              const itemPriceEl = element.closest('.fbt-item').querySelector('.fbt-item-price');
                              if (itemPriceEl) itemPriceEl.textContent = formatMoney(price);
                              element.closest('.fbt-item').setAttribute('data-price', price);
                            }
                            calculateTotal();
                          });
                        });

                        calculateTotal();

                        submitBtn.addEventListener('click', () => {
                          submitBtn.classList.add('loading');
                          const items = [];
                          
                          const mainVarId = container.querySelector('#fbt-variant-main').value;
                          items.push({ id: parseInt(mainVarId), quantity: 1 });

                          const cb1 = container.querySelector('#fbt-checkbox-1');
                          if (cb1 && cb1.checked) {
                            const varId1 = container.querySelector('#fbt-variant-1').value;
                            items.push({ id: parseInt(varId1), quantity: 1 });
                          }

                          const cb2 = container.querySelector('#fbt-checkbox-2');
                          if (cb2 && cb2.checked) {
                            const varId2 = container.querySelector('#fbt-variant-2').value;
                            items.push({ id: parseInt(varId2), quantity: 1 });
                          }

                          const cart = document.querySelector('cart-notification') || document.querySelector('cart-drawer');
                          const sections = cart ? cart.getSectionsToRender().map((s) => s.id) : [];

                          const formData = {
                            items: items,
                            sections: sections,
                            sections_url: window.location.pathname
                          };

                          fetch(`${window.routes.cart_add_url}`, {
                            method: 'POST',
                            headers: {
                              'Content-Type': 'application/json',
                              'X-Requested-With': 'XMLHttpRequest'
                            },
                            body: JSON.stringify(formData)
                          })
                          .then(response => response.json())
                          .then(response => {
                            submitBtn.classList.remove('loading');
                            if (response.status) {
                              alert(response.description || response.message);
                              return;
                            }
                            if (cart) {
                              cart.renderContents(response);
                            } else {
                              window.location = window.routes.cart_url;
                            }
                          })
                          .catch(error => {
                            console.error('Error adding combo to cart:', error);
                            submitBtn.classList.remove('loading');
                          });
                        });
                      })();
                    </script>
                  {%- endif -%}
              {%- endcase -%}
            {%- endfor -%}
            <a href="{{ product.url }}" class="link product__view-details animate-arrow">
              {{ 'products.product.view_full_details' | t }}
              {{- 'icon-arrow.svg' | inline_asset_content -}}
            </a>
          </section>
        </div>
      </div>

      {% render 'product-media-modal', variant_images: variant_images %}

      {% assign popups = section.blocks | where: 'type', 'popup' %}
      {%- for block in popups -%}
        <modal-dialog id="PopupModal-{{ block.id }}" class="product-popup-modal" {{ block.shopify_attributes }}>
          <div
            role="dialog"
            aria-label="{{ block.settings.text }}"
            aria-modal="true"
            class="product-popup-modal__content"
            tabindex="-1"
          >
            <button
              id="ModalClose-{{ block.id }}"
              type="button"
              class="product-popup-modal__toggle"
              aria-label="{{ 'accessibility.close' | t }}"
            >
              {{- 'icon-close.svg' | inline_asset_content -}}
            </button>
            <div class="product-popup-modal__content-info">
              <h1 class="h2">{{ block.settings.page.title | escape }}</h1>
              {{ block.settings.page.content }}
            </div>
          </div>
        </modal-dialog>
      {%- endfor -%}

      {%- if product.media.size > 0 -%}
        <script src="{{ 'product-modal.js' | asset_url }}" defer="defer"></script>
        <script src="{{ 'media-gallery.js' | asset_url }}" defer="defer"></script>
      {%- endif -%}

      {%- if first_3d_model -%}
        <script type="application/json" id="ProductJSON-{{ product.id }}">
          {{ product.media | where: 'media_type', 'model' | json }}
        </script>
        <script src="{{ 'product-model.js' | asset_url }}" defer></script>
      {%- endif -%}

      {%- liquid
        if product.selected_or_first_available_variant.featured_media
          assign seo_media = product.selected_or_first_available_variant.featured_media
        else
          assign seo_media = product.featured_media
        endif
      -%}

      <script type="application/ld+json">
        {{ product | structured_data }}
      </script>

      {%- liquid
        assign color_option_index = null
        for option in product.options
          assign downcased_name = option | downcase
          if downcased_name contains 'color' or downcased_name contains 'colour' or downcased_name contains 'màu'
            assign color_option_index = forloop.index0
            break
          endif
        endfor
      -%}

      <div class="sticky-add-to-cart mobile-only" id="StickyAddToCart-{{ section.id }}">
        <div class="sticky-add-to-cart__content page-width">
          <div class="sticky-add-to-cart__info">
            {%- if product.selected_or_first_available_variant.featured_media != null -%}
              <img
                src="{{ product.selected_or_first_available_variant.featured_media | image_url: width: 100 }}"
                id="StickyImage-{{ section.id }}"
                class="sticky-add-to-cart__image"
                alt=""
                width="50"
                height="50"
                loading="lazy"
              >
            {%- endif -%}
            <div class="sticky-add-to-cart__details">
              <span class="sticky-add-to-cart__title">{{ product.title }}</span>
              <span class="sticky-add-to-cart__variant" id="StickyVariantText-{{ section.id }}">
                {%- unless product.has_only_default_variant -%}
                  {{ product.selected_or_first_available_variant.title }}
                {%- endunless -%}
              </span>
            </div>
          </div>
          <div class="sticky-add-to-cart__actions">
            <div class="sticky-add-to-cart__price" id="StickyPrice-{{ section.id }}">
              {%- render 'price', product: product, use_variant: true, show_badges: false -%}
            </div>
            <button
              type="button"
              class="button button--primary sticky-add-to-cart__submit"
              id="StickySubmit-{{ section.id }}"
              {% if product.selected_or_first_available_variant.available == false %}
                disabled
              {% endif %}
            >
              <span>
                {%- if product.selected_or_first_available_variant.available -%}
                  {{ 'products.product.add_to_cart' | t }}
                {%- else -%}
                  {{ 'products.product.sold_out' | t }}
                {%- endif -%}
              </span>
            </button>
          </div>
        </div>
      </div>

      <script>
        window.addEventListener('DOMContentLoaded', () => {
          const sectionId = '{{ section.id }}';
          const colorOptionIndex = {{ color_option_index | json }};
          
          // 1. Sticky Add to Cart elements
          const mainButton = document.getElementById(`ProductSubmitButton-${sectionId}`);
          const stickyBar = document.getElementById(`StickyAddToCart-${sectionId}`);
          const stickySubmit = document.getElementById(`StickySubmit-${sectionId}`);
          
          // Intersection Observer to show/hide sticky bar on mobile
          if (mainButton && stickyBar) {
            const observer = new IntersectionObserver((entries) => {
              entries.forEach(entry => {
                if (!entry.isIntersecting && entry.boundingClientRect.top < 0) {
                  stickyBar.classList.add('is-visible');
                } else {
                  stickyBar.classList.remove('is-visible');
                }
              });
            }, {
              root: null,
              threshold: 0
            });
            observer.observe(mainButton);
          }
          
          // Trigger main button click from sticky button
          if (stickySubmit && mainButton) {
            stickySubmit.addEventListener('click', () => {
              if (!mainButton.hasAttribute('disabled')) {
                mainButton.click();
              }
            });
          }
          
          // 2. Variant Image Filtering logic
          function filterVariantImages(colorName) {
            if (colorOptionIndex === null || !colorName) return;
            
            const formattedColor = colorName.trim().toLowerCase();
            
            // Main slides
            const slides = document.querySelectorAll(`#Slider-Gallery-${sectionId} [data-media-color]`);
            // Thumbnails
            const thumbnails = document.querySelectorAll(`#Slider-Thumbnails-${sectionId} [data-media-color]`);
            
            let firstVisibleSlide = null;
            
            slides.forEach((slide) => {
              const mediaColor = slide.getAttribute('data-media-color').trim().toLowerCase();
              if (mediaColor === '' || mediaColor === formattedColor) {
                slide.style.display = '';
                slide.classList.remove('hidden');
                if (!firstVisibleSlide) {
                  firstVisibleSlide = slide;
                }
              } else {
                slide.style.display = 'none';
                slide.classList.add('hidden');
              }
            });
            
            thumbnails.forEach((thumb) => {
              const mediaColor = thumb.getAttribute('data-media-color').trim().toLowerCase();
              if (mediaColor === '' || mediaColor === formattedColor) {
                thumb.style.display = '';
                thumb.classList.remove('hidden');
              } else {
                thumb.style.display = 'none';
                thumb.classList.add('hidden');
              }
            });
            
            window.dispatchEvent(new Event('resize'));
            
            // Set active media to first visible image
            if (firstVisibleSlide) {
              const mediaGallery = document.getElementById(`MediaGallery-${sectionId}`);
              if (mediaGallery && typeof mediaGallery.setActiveMedia === 'function') {
                const mediaId = firstVisibleSlide.getAttribute('data-media-id');
                if (mediaId) {
                  mediaGallery.setActiveMedia(mediaId, false);
                }
              }
            }
          }
          
          // Helper to get checked color input from DOM
          function getSelectedColorFromDOM() {
            const colorInput = document.querySelector('fieldset[name*="color"] input:checked, fieldset[name*="Color"] input:checked, fieldset[name*="màu"] input:checked, select[name*="color"] option:checked, select[name*="Color"] option:checked, select[name*="màu"] option:checked');
            return colorInput ? (colorInput.value || colorInput.textContent).trim() : null;
          }
          
          // Initial run
          if (colorOptionIndex !== null) {
            const initialColor = getSelectedColorFromDOM();
            if (initialColor) {
              filterVariantImages(initialColor);
            }
          }
          
          // Subscribe to pubsub variantChange events
          if (typeof subscribe === 'function' && typeof PUB_SUB_EVENTS !== 'undefined') {
            subscribe(PUB_SUB_EVENTS.variantChange, (event) => {
              if (event.data.sectionId !== sectionId) return;
              
              const variant = event.data.variant;
              
              // 1. Sync Sticky bar
              const stickyImage = document.getElementById(`StickyImage-${sectionId}`);
              const stickyVariantText = document.getElementById(`StickyVariantText-${sectionId}`);
              const stickyPrice = document.getElementById(`StickyPrice-${sectionId}`);
              
              if (variant) {
                if (stickyImage && variant.featured_media) {
                  stickyImage.src = variant.featured_media.preview_image.src + '&width=100';
                }
                if (stickyVariantText) {
                  stickyVariantText.textContent = variant.title;
                }
                if (stickyPrice) {
                  const newPrice = event.data.html.getElementById(`price-${sectionId}`);
                  if (newPrice) {
                    stickyPrice.innerHTML = newPrice.innerHTML;
                  }
                }
                if (stickySubmit) {
                  const mainSubmit = event.data.html.getElementById(`ProductSubmitButton-${sectionId}`);
                  if (mainSubmit) {
                    const mainText = mainSubmit.querySelector('span')?.textContent || 'Add to Cart';
                    stickySubmit.querySelector('span').textContent = mainText;
                    stickySubmit.disabled = mainSubmit.hasAttribute('disabled');
                  }
                }
                
                if (colorOptionIndex !== null) {
                  const selectedColor = variant.options[colorOptionIndex];
                  if (selectedColor) {
                    filterVariantImages(selectedColor);
                  }
                }
              } else {
                if (stickySubmit) {
                  stickySubmit.disabled = true;
                  stickySubmit.querySelector('span').textContent = window.variantStrings.unavailable;
                }
                
                if (colorOptionIndex !== null) {
                  const selectedColor = getSelectedColorFromDOM();
                  if (selectedColor) {
                    filterVariantImages(selectedColor);
                  }
                }
              }
            });
          }
        });
      </script>
    </div>
  </product-component>
</product-info>

{%- liquid
  assign product_type = product.type | downcase
  assign size_guide_type = 't-shirt'
  
  if product_type contains 'hoodie' or product_type contains 'áo mũ'
    assign size_guide_type = 'hoodie'
  elsif product_type contains 'sweatshirt' or product_type contains 'áo nỉ'
    assign size_guide_type = 'sweatshirt'
  elsif product_type contains 'mug' or product_type contains 'ly' or product_type contains 'cốc'
    assign size_guide_type = 'mug'
  else
    for tag in product.tags
      assign tag_downcase = tag | downcase
      if tag_downcase contains 'hoodie'
        assign size_guide_type = 'hoodie'
        break
      elsif tag_downcase contains 'sweatshirt'
        assign size_guide_type = 'sweatshirt'
        break
      elsif tag_downcase contains 'mug'
        assign size_guide_type = 'mug'
        break
      elsif tag_downcase contains 't-shirt' or tag_downcase contains 'tshirt' or tag_downcase contains 'shirt'
        assign size_guide_type = 't-shirt'
        break
      endif
    endfor
  endif
-%}

