                {%- when 'sold_counter' -%}
                  <div class="product__sold-counter" {{ block.shopify_attributes }}>
                    <div class="fomo-counter-item">
                      <span class="fomo-icon svg-wrapper fire-icon">
                        {{- 'icon-fire.svg' | inline_asset_content -}}
                      </span>
                      <span class="fomo-text">
                        <strong id="fomo-sold-count">--</strong> items sold in the last 24 hours
                      </span>
                    </div>
                    <div class="fomo-counter-item">
                      <span class="fomo-icon svg-wrapper eye-icon">
                        {{- 'icon-eye.svg' | inline_asset_content -}}
                      </span>
                      <span class="fomo-text">
                        <strong id="fomo-viewer-count">--</strong> people are viewing this product
                      </span>
                    </div>
                  </div>
                  <script>
                    (function() {
                      const minSold = {{ block.settings.min_sold | default: 12 }};
                      const maxSold = {{ block.settings.max_sold | default: 29 }};
                      const minViewers = {{ block.settings.min_viewers | default: 4 }};
                      const maxViewers = {{ block.settings.max_viewers | default: 12 }};

                      function getRandomInt(min, max) {
                        return Math.floor(Math.random() * (max - min + 1)) + min;
                      }

                      const soldEl = document.getElementById('fomo-sold-count');
                      const viewersEl = document.getElementById('fomo-viewer-count');

                      if (soldEl) soldEl.textContent = getRandomInt(minSold, maxSold);
                      if (viewersEl) {
                        let viewers = getRandomInt(minViewers, maxViewers);
                        viewersEl.textContent = viewers;
                        
                        setInterval(() => {
                          let change = Math.floor(Math.random() * 3) - 1;
                          viewers = Math.max(minViewers, Math.min(maxViewers, viewers + change));
                          viewersEl.textContent = viewers;
                        }, 10000);
                      }
                    })();
                  </script>

                {%- when 'personalization_text' -%}
                  <div class="product__personalization-text product-form__input" {{ block.shopify_attributes }}>
                    <label class="form__label" for="PersonalizationText-{{ block.id }}-{{ section.id }}">
                      {{ block.settings.label | escape }}
                      {% if block.settings.required %}<span class="required" style="color: var(--gradient-base-accent-1);">*</span>{% endif %}
                    </label>
                    <div class="personalization-input-wrapper">
                      <input
                        type="text"
                        id="PersonalizationText-{{ block.id }}-{{ section.id }}"
                        class="personalization-text-input"
                        name="properties[{{ block.settings.label | escape }}]"
                        placeholder="{{ block.settings.placeholder | escape }}"
                        maxlength="{{ block.settings.max_chars | default: 25 }}"
                        {% if block.settings.required %}required{% endif %}
                        data-required="{{ block.settings.required }}"
                        data-label="{{ block.settings.label | escape }}"
                        form="{{ product_form_id }}"
                      >
                      <div class="personalization-text-counter">
                        <span class="char-count">0</span> / {{ block.settings.max_chars | default: 25 }}
                      </div>
                      <div class="personalization-error-message hidden" style="color: var(--gradient-base-accent-1); margin-top: 0.5rem; font-size: 1.2rem;">
                        This field is required.
                      </div>
                    </div>
                  </div>
                  <script>
                    (function() {
                      const input = document.getElementById('PersonalizationText-{{ block.id }}-{{ section.id }}');
                      if (!input) return;
                      const wrapper = input.closest('.product__personalization-text');
                      const counter = wrapper.querySelector('.char-count');
                      const errorMsg = wrapper.querySelector('.personalization-error-message');

                      input.addEventListener('input', () => {
                        counter.textContent = input.value.length;
                        if (input.value.trim() !== '') {
                          errorMsg.classList.add('hidden');
                          input.classList.remove('input-error');
                        }
                      });

                      // Attach capturing validator to form submit
                      const form = document.getElementById('{{ product_form_id }}');
                      if (form && !window.personalizationSubmitInterceptorAttached) {
                        window.personalizationSubmitInterceptorAttached = true;
                        form.addEventListener('submit', function(evt) {
                          let hasError = false;
                          
                          // Validate Text inputs
                          form.querySelectorAll('.personalization-text-input').forEach(ti => {
                            const isReq = ti.getAttribute('data-required') === 'true';
                            const tiWrapper = ti.closest('.product__personalization-text');
                            const tiError = tiWrapper.querySelector('.personalization-error-message');
                            if (isReq && ti.value.trim() === '') {
                              hasError = true;
                              ti.classList.add('input-error');
                              tiError.classList.remove('hidden');
                            } else {
                              ti.classList.remove('input-error');
                              tiError.classList.add('hidden');
                            }
                          });

                          // Validate File inputs
                          form.querySelectorAll('.personalization-file-input').forEach(fi => {
                            const isReq = fi.getAttribute('data-required') === 'true';
                            const fiWrapper = fi.closest('.product__personalization-file');
                            const fiError = fiWrapper.querySelector('.personalization-error-message');
                            if (isReq && !fi.value) {
                              hasError = true;
                              fi.classList.add('input-error');
                              fiError.classList.remove('hidden');
                            } else {
                              fi.classList.remove('input-error');
                              fiError.classList.add('hidden');
                            }
                          });

                          if (hasError) {
                            evt.preventDefault();
                            evt.stopPropagation();
                            evt.stopImmediatePropagation();
                          }
                        }, true);
                      }
                    })();
                  </script>

                {%- when 'personalization_file' -%}
                  <div class="product__personalization-file product-form__input" {{ block.shopify_attributes }}>
                    <label class="form__label">
                      {{ block.settings.label | escape }}
                      {% if block.settings.required %}<span class="required" style="color: var(--gradient-base-accent-1);">*</span>{% endif %}
                    </label>
                    <div class="personalization-file-wrapper" style="position: relative;">
                      <div class="personalization-file-upload-zone">
                        <input
                          type="file"
                          id="PersonalizationFile-{{ block.id }}-{{ section.id }}"
                          class="personalization-file-input"
                          name="properties[{{ block.settings.label | escape }}]"
                          accept="image/*"
                          {% if block.settings.required %}required{% endif %}
                          data-required="{{ block.settings.required }}"
                          data-label="{{ block.settings.label | escape }}"
                          form="{{ product_form_id }}"
                        >
                        <div class="upload-zone-prompt">
                          <span class="upload-icon">
                            <svg class="icon icon-upload" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                              <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path>
                              <polyline points="17 8 12 3 7 8"></polyline>
                              <line x1="12" y1="3" x2="12" y2="15"></line>
                            </svg>
                          </span>
                          <span class="upload-text">Click to upload image</span>
                        </div>
                      </div>
                      
                      <div class="personalization-file-preview hidden">
                        <img class="preview-image" src="data:image/gif;base64,R0lGODlhAQABAIAAAAAAAP///yH5BAEAAAAALAAAAAABAAEAAAIBRAA7" alt="Preview" width="100" height="100">
                        <button type="button" class="preview-remove-btn button button--secondary">
                          <span class="svg-wrapper" style="width: 1.5rem; height: 1.5rem;">
                            {{- 'icon-remove.svg' | inline_asset_content -}}
                          </span>
                          Remove
                        </button>
                      </div>
                      
                      <div class="personalization-error-message hidden" style="color: var(--gradient-base-accent-1); margin-top: 0.5rem; font-size: 1.2rem;">
                        This file is required.
                      </div>
                    </div>
                  </div>
                  <script>
                    (function() {
                      const fileInput = document.getElementById('PersonalizationFile-{{ block.id }}-{{ section.id }}');
                      if (!fileInput) return;
                      
                      const wrapper = fileInput.closest('.product__personalization-file');
                      const uploadZone = wrapper.querySelector('.personalization-file-upload-zone');
                      const previewZone = wrapper.querySelector('.personalization-file-preview');
                      const previewImg = wrapper.querySelector('.preview-image');
                      const removeBtn = wrapper.querySelector('.preview-remove-btn');
                      const errorMsg = wrapper.querySelector('.personalization-error-message');

                      fileInput.addEventListener('change', function() {
                        const file = this.files[0];
                        if (file) {
                          if (!file.type.startsWith('image/')) {
                            alert('Please select an image file.');
                            this.value = '';
                            return;
                          }
                          const reader = new FileReader();
                          reader.onload = function(e) {
                            previewImg.src = e.target.result;
                            uploadZone.classList.add('hidden');
                            previewZone.classList.remove('hidden');
                            errorMsg.classList.add('hidden');
                            fileInput.classList.remove('input-error');
                          };
                          reader.readAsDataURL(file);
                        }
                      });

                      removeBtn.addEventListener('click', function() {
                        fileInput.value = '';
                        previewImg.src = '';
                        previewZone.classList.add('hidden');
                        uploadZone.classList.remove('hidden');
                      });
                    })();
                  </script>

                {%- when 'quantity_breaks' -%}
                  <div class="product__quantity-breaks" {{ block.shopify_attributes }}>
                    {%- if block.settings.title != blank -%}
                      <h3 class="quantity-breaks-title h4">{{ block.settings.title }}</h3>
                    {%- endif -%}
                    <div class="quantity-breaks-grid">
                      {%- if block.settings.qty_1 > 0 -%}
                        <div class="quantity-break-card active" data-qty="{{ block.settings.qty_1 | default: 1 }}">
                          {%- if block.settings.badge_1 != blank -%}
                            <div class="qb-card-badge">{{ block.settings.badge_1 | escape }}</div>
                          {%- endif -%}
                          <div class="qb-card-qty">Buy {{ block.settings.qty_1 }}</div>
                          <div class="qb-card-discount">{{ block.settings.discount_1 | escape }}</div>
                        </div>
                      {%- endif -%}
                      {%- if block.settings.qty_2 > 0 -%}
                        <div class="quantity-break-card" data-qty="{{ block.settings.qty_2 | default: 2 }}">
                          {%- if block.settings.badge_2 != blank -%}
                            <div class="qb-card-badge">{{ block.settings.badge_2 | escape }}</div>
                          {%- endif -%}
                          <div class="qb-card-qty">Buy {{ block.settings.qty_2 }}</div>
                          <div class="qb-card-discount">{{ block.settings.discount_2 | escape }}</div>
                        </div>
                      {%- endif -%}
                      {%- if block.settings.qty_3 > 0 -%}
                        <div class="quantity-break-card" data-qty="{{ block.settings.qty_3 | default: 3 }}">
                          {%- if block.settings.badge_3 != blank -%}
                            <div class="qb-card-badge">{{ block.settings.badge_3 | escape }}</div>
                          {%- endif -%}
                          <div class="qb-card-qty">Buy {{ block.settings.qty_3 }}+</div>
                          <div class="qb-card-discount">{{ block.settings.discount_3 | escape }}</div>
                        </div>
                      {%- endif -%}
                    </div>
                  </div>
                  <script>
                    (function() {
                      const cards = document.querySelectorAll('.quantity-break-card');
                      const qtyInput = document.getElementById('Quantity-{{ section.id }}');
                      
                      if (!qtyInput) return;

                      cards.forEach(card => {
                        card.addEventListener('click', () => {
                          const qty = card.getAttribute('data-qty');
                          qtyInput.value = qty;
                          
                          qtyInput.dispatchEvent(new Event('input', { bubbles: true }));
                          qtyInput.dispatchEvent(new Event('change', { bubbles: true }));

                          cards.forEach(c => c.classList.remove('active'));
                          card.classList.add('active');
                        });
                      });

                      qtyInput.addEventListener('change', () => {
                        const val = parseInt(qtyInput.value) || 1;
                        let matched = false;
                        
                        cards.forEach(card => {
                          const cardQty = parseInt(card.getAttribute('data-qty'));
                          if (cardQty === val) {
                            cards.forEach(c => c.classList.remove('active'));
                            card.classList.add('active');
                            matched = true;
                          }
                        });
                        
                        if (!matched) {
                          cards.forEach(c => c.classList.remove('active'));
                        }
                      });
                    })();
                  </script>

