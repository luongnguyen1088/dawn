                    {%- endif -%}
                    <div class="product__trust-badges-list">
                      <div class="product__trust-badge-item">
                        <span class="product__trust-badge-icon svg-wrapper">
                          {{- 'icon-padlock.svg' | inline_asset_content -}}
                        </span>
                        <span class="product__trust-badge-text">Secure Checkout</span>
                      </div>
                      <div class="product__trust-badge-item">
                        <span class="product__trust-badge-icon svg-wrapper">
                          {{- 'icon-star.svg' | inline_asset_content -}}
                        </span>
                        <span class="product__trust-badge-text">Satisfaction Guaranteed</span>
                      </div>
                      <div class="product__trust-badge-item">
                        <span class="product__trust-badge-icon svg-wrapper">
                          {{- 'icon-return.svg' | inline_asset_content -}}
